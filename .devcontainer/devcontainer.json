{
  "name": "compass-website",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "mounts": [
    "source=${localWorkspaceFolder}/.claude-memory,target=/home/node/.claude-memory,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/node/.claude.json,type=bind,consistency=cached"
  ],
  "features": {},
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/.claude-memory && mkdir -p ${HOME}/.claude && touch ${HOME}/.claude.json",
  "onCreateCommand": "sudo mkdir -p /home/node/.vscode-server/data/User/globalStorage && sudo ln -snf /home/node/.claude-memory /home/node/.vscode-server/data/User/globalStorage/anthropic.claude-code && sudo chown -R node:node /home/node/.vscode-server /home/node/.claude-memory /home/node/.claude /home/node/.claude.json",
  "postCreateCommand": "npm install -g @vue/cli",
  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Vue CLI Dev Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}